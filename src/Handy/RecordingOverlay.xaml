<Window x:Class="Handy.RecordingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        IsHitTestVisible="False"
        Focusable="False"
        SizeToContent="WidthAndHeight">
    <Border CornerRadius="10" Padding="14,8" Background="#CC111111">
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="StateLabel" Text="Listening" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <!-- Live input-level bars; hidden during transcription. -->
            <StackPanel x:Name="LevelBars" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0" Height="18">
                <Rectangle x:Name="Bar0" Width="3" Height="2" Margin="1,0" Fill="#E0403D" VerticalAlignment="Bottom" RadiusX="1.5" RadiusY="1.5"/>
                <Rectangle x:Name="Bar1" Width="3" Height="2" Margin="1,0" Fill="#E0403D" VerticalAlignment="Bottom" RadiusX="1.5" RadiusY="1.5"/>
                <Rectangle x:Name="Bar2" Width="3" Height="2" Margin="1,0" Fill="#E0403D" VerticalAlignment="Bottom" RadiusX="1.5" RadiusY="1.5"/>
                <Rectangle x:Name="Bar3" Width="3" Height="2" Margin="1,0" Fill="#E0403D" VerticalAlignment="Bottom" RadiusX="1.5" RadiusY="1.5"/>
                <Rectangle x:Name="Bar4" Width="3" Height="2" Margin="1,0" Fill="#E0403D" VerticalAlignment="Bottom" RadiusX="1.5" RadiusY="1.5"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
