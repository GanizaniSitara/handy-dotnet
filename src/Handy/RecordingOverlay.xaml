<Window x:Class="Handy.RecordingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        IsHitTestVisible="False"
        Focusable="False"
        SizeToContent="WidthAndHeight">
    <Border CornerRadius="16" Padding="14,7" Background="#CC000000">
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="StateLabel" Text="Listening"
                       Foreground="White" FontSize="12" FontWeight="Medium"
                       FontFamily="Segoe UI" VerticalAlignment="Center"/>
            <!-- Live input-level bars; hidden during transcription. -->
            <StackPanel x:Name="LevelBars" Orientation="Horizontal" VerticalAlignment="Center"
                        Margin="12,0,0,0" Height="20">
                <Rectangle x:Name="Bar0" Width="5" Height="2" Margin="1.5,0" Fill="#FFA2CAFA" VerticalAlignment="Bottom" RadiusX="2" RadiusY="2"/>
                <Rectangle x:Name="Bar1" Width="5" Height="2" Margin="1.5,0" Fill="#FFA2CAFA" VerticalAlignment="Bottom" RadiusX="2" RadiusY="2"/>
                <Rectangle x:Name="Bar2" Width="5" Height="2" Margin="1.5,0" Fill="#FFA2CAFA" VerticalAlignment="Bottom" RadiusX="2" RadiusY="2"/>
                <Rectangle x:Name="Bar3" Width="5" Height="2" Margin="1.5,0" Fill="#FFA2CAFA" VerticalAlignment="Bottom" RadiusX="2" RadiusY="2"/>
                <Rectangle x:Name="Bar4" Width="5" Height="2" Margin="1.5,0" Fill="#FFA2CAFA" VerticalAlignment="Bottom" RadiusX="2" RadiusY="2"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
