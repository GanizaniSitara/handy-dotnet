<Window x:Class="Handy.RecordingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        IsHitTestVisible="False"
        Focusable="False"
        SizeToContent="WidthAndHeight">
    <Border CornerRadius="10" Padding="14,8" Background="#CC111111">
        <StackPanel Orientation="Horizontal">
            <Ellipse x:Name="Dot" Width="12" Height="12" Fill="#E0403D" Margin="0,0,10,0">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Ellipse.Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1.0" To="0.25" Duration="0:0:0.6" AutoReverse="True"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
            <TextBlock x:Name="Label" Text="Recording" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
