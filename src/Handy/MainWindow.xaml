<Window x:Class="Handy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Handy.NET — Settings" Width="780" Height="640"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Background}"
        Closing="OnClosing">
    <DockPanel LastChildFill="True">

        <!-- ════════════════════════════════════════════════ SIDEBAR ════ -->
        <Border DockPanel.Dock="Left" Width="170"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0"
                Background="{StaticResource Brush.Background}">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="16,16,0,18">
                    <Path x:Name="LogoPath" Width="22" Height="24" Stretch="Uniform"
                          Fill="{StaticResource Brush.BackgroundUI}"
                          VerticalAlignment="Center"/>
                    <TextBlock Text="Handy.NET" Style="{StaticResource Text.AppTitle}"
                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource Brush.Border}" Margin="10,0,10,8"/>

                <RadioButton DockPanel.Dock="Top" x:Name="NavGeneral"  Style="{StaticResource SidebarItem}" Content="General"  IsChecked="True"
                             Checked="OnNavChecked"/>
                <RadioButton DockPanel.Dock="Top" x:Name="NavAdvanced" Style="{StaticResource SidebarItem}" Content="Advanced"
                             Checked="OnNavChecked"/>
                <RadioButton DockPanel.Dock="Top" x:Name="NavModels"   Style="{StaticResource SidebarItem}" Content="Models"
                             Checked="OnNavChecked"/>
                <RadioButton DockPanel.Dock="Top" x:Name="NavLog"      Style="{StaticResource SidebarItem}" Content="Log"
                             Checked="OnNavChecked"/>

                <TextBlock DockPanel.Dock="Bottom" x:Name="VersionText"
                           Margin="16,0,16,14"
                           FontSize="11"
                           Foreground="{StaticResource Brush.TextSubtle}"/>
            </DockPanel>
        </Border>

        <!-- ════════════════════════════════════════════════ FOOTER ════ -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource Brush.Background}"
                Padding="14,10">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource SecondaryButton}" Content="Minimize" Click="OnHide" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource PrimaryButton}"   Content="Apply" Click="OnApply"/>
                </StackPanel>
                <TextBlock x:Name="SaveStatusText" VerticalAlignment="Center" Margin="2,0,0,0"
                           Foreground="{StaticResource Brush.Success}" FontWeight="SemiBold"/>
            </DockPanel>
        </Border>

        <!-- ════════════════════════════════════════════════ CONTENT ═══ -->
        <Grid x:Name="ContentRoot">

            <!-- ─────────────────────────────────────────── GENERAL ──── -->
            <ScrollViewer x:Name="PanelGeneral" VerticalScrollBarVisibility="Auto" Padding="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="SHORTCUTS" Style="{StaticResource Text.SectionGroupTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowFirst}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="240"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Transcribe shortcut" Style="{StaticResource Text.SettingLabel}"/>
                                    <TextBox   Grid.Column="1" x:Name="HotkeyBox" KeyDown="OnHotkeyBoxKeyDown"
                                               IsReadOnly="True" Focusable="True"
                                               ToolTip="Click, then press the desired combination."/>
                                    <CheckBox  Grid.Column="2" x:Name="PttCheck" Content="Push-to-talk" Margin="12,0,0,0"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="240"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Cancel shortcut" Style="{StaticResource Text.SettingLabel}"/>
                                    <TextBox   Grid.Column="1" x:Name="CancelBox" KeyDown="OnCancelBoxKeyDown"
                                               IsReadOnly="True" Focusable="True"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="240"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Copy last transcription" Style="{StaticResource Text.SettingLabel}"
                                               ToolTip="Recovery hotkey: copies the most recent transcript back onto the clipboard so you can paste it manually."/>
                                    <TextBox   Grid.Column="1" x:Name="CopyLastBox" KeyDown="OnCopyLastBoxKeyDown"
                                               IsReadOnly="True" Focusable="True"
                                               ToolTip="Click, then press the desired combination."/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="SOUND" Style="{StaticResource Text.SectionGroupTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowFirst}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="320"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Microphone" Style="{StaticResource Text.SettingLabel}"/>
                                    <ComboBox  Grid.Column="1" x:Name="MicCombo"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="320"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Mute while recording" Style="{StaticResource Text.SettingLabel}"
                                               ToolTip="Not implemented in this port — requires IAudioSessionManager2 COM."/>
                                    <CheckBox  Grid.Column="1" IsEnabled="False" Content="(not implemented)"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="BEEPS" Style="{StaticResource Text.SectionGroupTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowFirst}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Beep on" Style="{StaticResource Text.SettingLabel}"/>
                                    <CheckBox  Grid.Column="1" x:Name="BeepStartCheck"  Content="Start"  Margin="0,0,16,0"/>
                                    <CheckBox  Grid.Column="2" x:Name="BeepStopCheck"   Content="Stop"   Margin="0,0,16,0"/>
                                    <CheckBox  Grid.Column="3" x:Name="BeepCancelCheck" Content="Cancel"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Beep volume" Style="{StaticResource Text.SettingLabel}"/>
                                    <Slider    Grid.Column="1" x:Name="BeepVolumeSlider" Minimum="0" Maximum="1"
                                               TickFrequency="0.1" IsSnapToTickEnabled="False"
                                               ValueChanged="OnBeepVolumeChanged"/>
                                    <TextBlock Grid.Column="2" x:Name="BeepVolumePct" TextAlignment="Right"
                                               VerticalAlignment="Center" FontSize="12"
                                               Foreground="{StaticResource Brush.TextSubtle}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="VOICE ACTIVITY (VAD)" Style="{StaticResource Text.SectionGroupTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowFirst}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Trim silence with VAD" Style="{StaticResource Text.SettingLabel}"/>
                                    <CheckBox  Grid.Column="1" x:Name="VadCheck"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Threshold" Style="{StaticResource Text.SettingLabel}"/>
                                    <TextBox   Grid.Column="1" x:Name="VadThresholdBox"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Padding (ms)" Style="{StaticResource Text.SettingLabel}"/>
                                    <TextBox   Grid.Column="1" x:Name="VadPaddingBox"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Max gap (ms)" Style="{StaticResource Text.SettingLabel}"
                                               ToolTip="Longest mid-recording pause VAD will tolerate before closing the speech segment. Default: 30000 (30 s)."/>
                                    <TextBox   Grid.Column="1" x:Name="VadMaxSilenceMsBox"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ─────────────────────────────────────────── ADVANCED ─── -->
            <ScrollViewer x:Name="PanelAdvanced" VerticalScrollBarVisibility="Auto" Padding="0,0,0,14"
                          Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="OUTPUT" Style="{StaticResource Text.SectionGroupTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowFirst}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Paste method" Style="{StaticResource Text.SettingLabel}"/>
                                    <ComboBox  Grid.Column="1" x:Name="PasteMethodCombo"
                                               ToolTip="CtrlV is the safe default. Direct types char-by-char (handles apps that eat clipboard paste). ShiftInsert / CtrlShiftV are terminal-friendly. None just copies to clipboard.">
                                        <ComboBoxItem Content="CtrlV"/>
                                        <ComboBoxItem Content="Direct"/>
                                        <ComboBoxItem Content="None"/>
                                        <ComboBoxItem Content="ShiftInsert"/>
                                        <ComboBoxItem Content="CtrlShiftV"/>
                                    </ComboBox>
                                    <CheckBox  Grid.Column="2" x:Name="TrailingSpaceCheck" Content="Trailing space" Margin="12,0,0,0"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="After-paste clipboard" Style="{StaticResource Text.SettingLabel}"
                                               ToolTip="DontModify restores your previous clipboard; CopyToClipboard leaves the transcript on it."/>
                                    <ComboBox  Grid.Column="1" x:Name="ClipboardCombo">
                                        <ComboBoxItem Content="DontModify"/>
                                        <ComboBoxItem Content="CopyToClipboard"/>
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Always copy transcription to clipboard"
                                               Style="{StaticResource Text.SettingLabel}"
                                               ToolTip="Leave the final transcript on the clipboard after every successful dictation, even if paste restores the previous clipboard."/>
                                    <CheckBox  Grid.Column="1" x:Name="AlwaysCopyTranscriptCheck"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Auto-submit" Style="{StaticResource Text.SettingLabel}"
                                               ToolTip="Send a key after paste — e.g. Enter to send the chat message."/>
                                    <ComboBox  Grid.Column="1" x:Name="AutoSubmitCombo">
                                        <ComboBoxItem Content="None"/>
                                        <ComboBoxItem Content="Enter"/>
                                        <ComboBoxItem Content="CtrlEnter"/>
                                    </ComboBox>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="DOMAIN TERMS" Style="{StaticResource Text.SectionGroupTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowFirst}">
                                <DataGrid x:Name="DomainCorrectionsGrid"
                                          Height="190"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="True"
                                          CanUserDeleteRows="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="On"
                                                                Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="44"/>
                                        <DataGridTextColumn Header="Canonical"
                                                            Binding="{Binding To, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="130"/>
                                        <DataGridTextColumn Header="Variants"
                                                            Binding="{Binding VariantsText, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="170"/>
                                        <DataGridTextColumn Header="Require Any"
                                                            Binding="{Binding RequiredContextText, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="140"/>
                                        <DataGridTextColumn Header="Block"
                                                            Binding="{Binding BlockedContextText, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="110"/>
                                        <DataGridCheckBoxColumn Header="Case"
                                                                Binding="{Binding CaseSensitive, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="52"/>
                                        <DataGridTextColumn Header="Notes"
                                                            Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="180"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="CAPTURE TIMING" Style="{StaticResource Text.SectionGroupTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowFirst}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Paste delay (ms)" Style="{StaticResource Text.SettingLabel}"/>
                                    <TextBox   Grid.Column="1" x:Name="PasteDelayBox"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Pre-roll (ms)" Style="{StaticResource Text.SettingLabel}"
                                               ToolTip="Include this many ms of audio captured BEFORE the hotkey press."/>
                                    <TextBox   Grid.Column="1" x:Name="PreRollBox"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Post-roll (ms)" Style="{StaticResource Text.SettingLabel}"
                                               ToolTip="Keep recording this many ms AFTER the key is released."/>
                                    <TextBox   Grid.Column="1" x:Name="PostRollBox"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Direct per-char delay (ms)" Style="{StaticResource Text.SettingLabel}"
                                               ToolTip="Per-char throttle for Direct paste into LOCAL apps. 0 = fastest; native desktops handle full speed. Citrix gets its own delay in the CITRIX section below."/>
                                    <TextBox   Grid.Column="1" x:Name="DirectCharDelayBox"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="CITRIX" Style="{StaticResource Text.SectionGroupTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowFirst}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Direct per-char delay (ms)" Style="{StaticResource Text.SettingLabel}"
                                               ToolTip="Per-char throttle for Direct paste when the foreground window is a Citrix client (CDViewer / wfica32 / Receiver / Workspace). Citrix forwards keystrokes through its own pipeline and drops or reorders Unicode events at full speed — a few ms here usually fixes garbling. Default 1."/>
                                    <TextBox   Grid.Column="1" x:Name="DirectCharDelayCitrixBox"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <TextBlock Style="{StaticResource Text.Hint}">
                                    Citrix detection auto-picks this delay only when the foreground process is a known Citrix client. Local apps keep the fast path above.
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="UI" Style="{StaticResource Text.SectionGroupTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowFirst}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="160"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Recording overlay" Style="{StaticResource Text.SettingLabel}"/>
                                    <ComboBox  Grid.Column="1" x:Name="OverlayCombo">
                                        <ComboBoxItem Content="None"/>
                                        <ComboBoxItem Content="Top"/>
                                        <ComboBoxItem Content="Bottom"/>
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <StackPanel Orientation="Horizontal">
                                    <CheckBox x:Name="ShowTrayCheck"   Content="Show tray icon"            Margin="0,0,20,0"/>
                                    <CheckBox x:Name="StartHiddenCheck" Content="Start hidden (tray only)" Margin="0,0,20,0"/>
                                    <CheckBox x:Name="AutostartCheck"   Content="Autostart on login"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="HISTORY" Style="{StaticResource Text.SectionGroupTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowFirst}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Keep last N entries" Style="{StaticResource Text.SettingLabel}"/>
                                    <TextBox   Grid.Column="1" x:Name="HistoryLimitBox"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Button Style="{StaticResource SecondaryButton}" Content="Open history browser…"
                                        HorizontalAlignment="Left" Click="OnOpenHistory"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ─────────────────────────────────────────── MODELS ───── -->
            <ScrollViewer x:Name="PanelModels" VerticalScrollBarVisibility="Auto" Padding="0,0,0,14"
                          Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="ACTIVE" Style="{StaticResource Text.SectionGroupTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowFirst}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="In use now" Style="{StaticResource Text.SettingLabel}"
                                               Foreground="{StaticResource Brush.TextSubtle}"/>
                                    <TextBlock Grid.Column="1" x:Name="ActiveModelSummaryText" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Status" Style="{StaticResource Text.SettingLabel}"
                                               Foreground="{StaticResource Brush.TextSubtle}"/>
                                    <TextBlock Grid.Column="1" x:Name="ActiveModelStatusText" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Path" Style="{StaticResource Text.SettingLabel}"
                                               Foreground="{StaticResource Brush.TextSubtle}"/>
                                    <TextBlock Grid.Column="1" x:Name="ActiveModelPathText"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                               Foreground="{StaticResource Brush.TextSubtle}" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="CHANGE MODEL" Style="{StaticResource Text.SectionGroupTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowFirst}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Backend" Style="{StaticResource Text.SettingLabel}"/>
                                    <ComboBox Grid.Column="1" x:Name="TranscriptionBackendCombo" SelectionChanged="OnModelSelectionChanged">
                                        <ComboBoxItem Content="Parakeet"/>
                                        <ComboBoxItem Content="Whisper"/>
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Parakeet variant" Style="{StaticResource Text.SettingLabel}"
                                               ToolTip="Auto prefers v3 if installed, else v2. Pick V2 or V3 to force a specific generation."/>
                                    <ComboBox Grid.Column="1" x:Name="ParakeetVariantCombo" SelectionChanged="OnModelSelectionChanged">
                                        <ComboBoxItem Content="Auto"/>
                                        <ComboBoxItem Content="V2"/>
                                        <ComboBoxItem Content="V3"/>
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Whisper model" Style="{StaticResource Text.SettingLabel}"/>
                                    <ComboBox Grid.Column="1" x:Name="WhisperModelCombo" SelectionChanged="OnModelSelectionChanged">
                                        <ComboBoxItem Content="tiny.en"/>
                                        <ComboBoxItem Content="tiny"/>
                                        <ComboBoxItem Content="base"/>
                                        <ComboBoxItem Content="small"/>
                                    </ComboBox>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Vocabulary prompt" Style="{StaticResource Text.SettingLabel}"/>
                                    <CheckBox Grid.Column="1" x:Name="WhisperPromptCheck"
                                              Content="Use glossary terms"
                                              VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Carry prompt" Style="{StaticResource Text.SettingLabel}"/>
                                    <CheckBox Grid.Column="1" x:Name="WhisperCarryPromptCheck"
                                              Content="Repeat across segments"
                                              VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Selected" Style="{StaticResource Text.SettingLabel}"
                                               Foreground="{StaticResource Brush.TextSubtle}"/>
                                    <TextBlock Grid.Column="1" x:Name="PendingModelSummaryText" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Effect" Style="{StaticResource Text.SettingLabel}"
                                               Foreground="{StaticResource Brush.TextSubtle}"/>
                                    <TextBlock Grid.Column="1" x:Name="PendingModelStatusText" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Path" Style="{StaticResource Text.SettingLabel}"
                                               Foreground="{StaticResource Brush.TextSubtle}"/>
                                    <TextBlock Grid.Column="1" x:Name="PendingModelPathText"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                               Foreground="{StaticResource Brush.TextSubtle}" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="DOWNLOAD PARAKEET" Style="{StaticResource Text.SectionGroupTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowFirst}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Variant" VerticalAlignment="Center" Margin="0,0,8,0"
                                               Style="{StaticResource Text.SettingLabel}"/>
                                    <ComboBox x:Name="DownloadVariantCombo" Width="80" SelectedIndex="0">
                                        <ComboBoxItem Content="V2"/>
                                        <ComboBoxItem Content="V3"/>
                                    </ComboBox>
                                    <Button Style="{StaticResource SecondaryButton}" x:Name="DownloadButton"
                                            Content="Download" Margin="12,0,12,0" Click="OnDownloadModel"/>
                                    <TextBlock x:Name="DownloadStatus" VerticalAlignment="Center"
                                               Foreground="{StaticResource Brush.TextSubtle}" FontSize="12"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <TextBlock Style="{StaticResource Text.Hint}">
                                    Parakeet V2 is English-only (~475 MB). V3 is multilingual (~478 MB).
                                    Models auto-discovered from %APPDATA%\Handy\models\ or upstream's cache at %APPDATA%\com.pais.handy\models\.
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="DOWNLOAD WHISPER" Style="{StaticResource Text.SectionGroupTitle}"/>
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Border Style="{StaticResource SettingsRowFirst}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Model" VerticalAlignment="Center" Margin="0,0,8,0"
                                               Style="{StaticResource Text.SettingLabel}"/>
                                    <ComboBox x:Name="DownloadWhisperModelCombo" Width="90" SelectedIndex="2">
                                        <ComboBoxItem Content="tiny.en"/>
                                        <ComboBoxItem Content="tiny"/>
                                        <ComboBoxItem Content="base"/>
                                        <ComboBoxItem Content="small"/>
                                    </ComboBox>
                                    <Button Style="{StaticResource SecondaryButton}" x:Name="DownloadWhisperButton"
                                            Content="Download" Margin="12,0,12,0" Click="OnDownloadWhisperModel"/>
                                    <TextBlock x:Name="DownloadWhisperStatus" VerticalAlignment="Center"
                                               Foreground="{StaticResource Brush.TextSubtle}" FontSize="12"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <TextBlock Style="{StaticResource Text.Hint}">
                                    Whisper.net uses GGML/whisper.cpp models stored under %APPDATA%\Handy\models\whisper\.
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ─────────────────────────────────────────── LOG ─────── -->
            <DockPanel x:Name="PanelLog" Margin="14,14,14,14" Visibility="Collapsed" LastChildFill="True">
                <Border DockPanel.Dock="Top" Padding="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Display" VerticalAlignment="Center" Margin="0,0,8,0"
                                   Style="{StaticResource Text.SettingLabel}"
                                   ToolTip="Which INFO lines appear in this Log panel. Warnings and errors always pass through."/>
                        <ComboBox x:Name="LogDisplayVerbosityCombo" Width="110" Margin="0,0,20,0"
                                  SelectionChanged="OnLogVerbosityChanged">
                            <ComboBoxItem Content="Quiet"/>
                            <ComboBoxItem Content="Normal"/>
                            <ComboBoxItem Content="Verbose"/>
                            <ComboBoxItem Content="Debug"/>
                        </ComboBox>
                        <TextBlock Text="File" VerticalAlignment="Center" Margin="0,0,8,0"
                                   Style="{StaticResource Text.SettingLabel}"
                                   ToolTip="Which INFO lines are written to %APPDATA%\Handy\handy.log on disk. Default Debug keeps the full forensic trail."/>
                        <ComboBox x:Name="LogFileVerbosityCombo" Width="110" Margin="0,0,20,0"
                                  SelectionChanged="OnLogVerbosityChanged">
                            <ComboBoxItem Content="Quiet"/>
                            <ComboBoxItem Content="Normal"/>
                            <ComboBoxItem Content="Verbose"/>
                            <ComboBoxItem Content="Debug"/>
                        </ComboBox>
                        <TextBlock VerticalAlignment="Center" FontSize="11"
                                   Foreground="{StaticResource Brush.TextSubtle}"
                                   Text="Quiet = Raw / Filter / Transcript only · Normal adds Paste &amp; startup · Verbose adds VAD / ASR / Flow / Diag · Debug adds HOOK firehose"/>
                    </StackPanel>
                </Border>
                <TextBox x:Name="LogBox" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                         Background="#FF1B1F23" Foreground="#FFE6EDF3"
                         BorderBrush="{StaticResource Brush.Border}" BorderThickness="1"
                         Padding="10" VerticalContentAlignment="Top"/>
            </DockPanel>

        </Grid>

    </DockPanel>
</Window>
