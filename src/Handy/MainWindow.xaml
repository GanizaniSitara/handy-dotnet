<Window x:Class="Handy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Handy — Settings" Width="680" Height="640"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Closing="OnClosing">
    <Window.Resources>
        <Thickness x:Key="RowMargin">0,4,0,4</Thickness>
        <Style x:Key="LabelCell" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" x:Name="Tabs">
            <!-- ═══════════════════════════════════════════════ GENERAL ═══ -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Text="SHORTCUTS" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,6"/>

                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Transcribe shortcut" Style="{StaticResource LabelCell}"/>
                            <TextBox   Grid.Column="1" x:Name="HotkeyBox" KeyDown="OnHotkeyBoxKeyDown"
                                       IsReadOnly="True" Focusable="True"
                                       ToolTip="Click, then press the desired combination."/>
                            <CheckBox  Grid.Column="2" x:Name="PttCheck" Content="Push-to-talk" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Cancel shortcut" Style="{StaticResource LabelCell}"/>
                            <TextBox   Grid.Column="1" x:Name="CancelBox" KeyDown="OnCancelBoxKeyDown"
                                       IsReadOnly="True" Focusable="True"/>
                        </Grid>

                        <TextBlock Text="SOUND" FontWeight="SemiBold" Foreground="#555" Margin="0,12,0,6"/>

                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Microphone" Style="{StaticResource LabelCell}"/>
                            <ComboBox  Grid.Column="1" x:Name="MicCombo"/>
                        </Grid>

                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Mute while recording"
                                       Style="{StaticResource LabelCell}"
                                       ToolTip="Not implemented in this port — requires IAudioSessionManager2 COM."/>
                            <CheckBox  Grid.Column="1" IsEnabled="False" Content="(not implemented)" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="BEEPS" FontWeight="SemiBold" Foreground="#555" Margin="0,12,0,6"/>
                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Beep on" Style="{StaticResource LabelCell}"/>
                            <CheckBox  Grid.Column="1" x:Name="BeepStartCheck"  Content="Start"  VerticalAlignment="Center"/>
                            <CheckBox  Grid.Column="3" x:Name="BeepStopCheck"   Content="Stop"   VerticalAlignment="Center"/>
                            <CheckBox  Grid.Column="6" x:Name="BeepCancelCheck" Content="Cancel" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Beep volume" Style="{StaticResource LabelCell}"/>
                            <Slider    Grid.Column="1" x:Name="BeepVolumeSlider" Minimum="0" Maximum="1" TickFrequency="0.1"
                                       IsSnapToTickEnabled="False" VerticalAlignment="Center"
                                       ValueChanged="OnBeepVolumeChanged"/>
                            <TextBlock Grid.Column="2" x:Name="BeepVolumePct" Style="{StaticResource LabelCell}" TextAlignment="Right"/>
                        </Grid>

                        <TextBlock Text="VOICE ACTIVITY (VAD)" FontWeight="SemiBold" Foreground="#555" Margin="0,12,0,6"/>
                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Trim silence with VAD" Style="{StaticResource LabelCell}"/>
                            <CheckBox  Grid.Column="1" x:Name="VadCheck" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Threshold" Style="{StaticResource LabelCell}"/>
                            <TextBox   Grid.Column="4" x:Name="VadThresholdBox"/>
                            <TextBlock Grid.Column="6" Text="Padding (ms)" Style="{StaticResource LabelCell}"/>
                            <TextBox   Grid.Column="7" x:Name="VadPaddingBox"/>
                        </Grid>
                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="2" Text="Max gap (ms)" Style="{StaticResource LabelCell}"
                                       ToolTip="Longest mid-recording pause VAD will tolerate before closing the speech segment. Raise this if long thinking pauses cause the second half of your utterance to be dropped. Default: 30000 (30 s)."/>
                            <TextBox   Grid.Column="3" x:Name="VadMaxSilenceMsBox"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════ ADVANCED ═══ -->
            <TabItem Header="Advanced">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Text="OUTPUT" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,6"/>

                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Paste method" Style="{StaticResource LabelCell}"/>
                            <ComboBox  Grid.Column="1" x:Name="PasteMethodCombo"
                                       ToolTip="CtrlV is the safe default. Direct types the text char-by-char (handles niche apps that eat clipboard paste). ShiftInsert / CtrlShiftV are terminal-friendly variants. None types nothing and just copies to clipboard (if CopyToClipboard is set).">
                                <ComboBoxItem Content="CtrlV"/>
                                <ComboBoxItem Content="Direct"/>
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="ShiftInsert"/>
                                <ComboBoxItem Content="CtrlShiftV"/>
                            </ComboBox>
                            <CheckBox  Grid.Column="2" x:Name="TrailingSpaceCheck" Content="Trailing space" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>

                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="After-paste clipboard" Style="{StaticResource LabelCell}"
                                       ToolTip="DontModify restores your previous clipboard after paste; CopyToClipboard leaves the transcript on it."/>
                            <ComboBox  Grid.Column="1" x:Name="ClipboardCombo">
                                <ComboBoxItem Content="DontModify"/>
                                <ComboBoxItem Content="CopyToClipboard"/>
                            </ComboBox>
                            <TextBlock Grid.Column="2" Text="Auto-submit" Style="{StaticResource LabelCell}" Margin="12,0,0,0"
                                       ToolTip="Send a key after paste — e.g. Enter to send the chat message."/>
                            <ComboBox  Grid.Column="3" x:Name="AutoSubmitCombo">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="Enter"/>
                                <ComboBoxItem Content="CtrlEnter"/>
                            </ComboBox>
                        </Grid>

                        <TextBlock Text="CAPTURE TIMING" FontWeight="SemiBold" Foreground="#555" Margin="0,12,0,6"/>
                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Paste delay (ms)" Style="{StaticResource LabelCell}"/>
                            <TextBox   Grid.Column="1" x:Name="PasteDelayBox"/>
                            <TextBlock Grid.Column="2" Text="Pre-roll (ms)"  Style="{StaticResource LabelCell}" Margin="12,0,0,0"
                                       ToolTip="Include this many ms of audio captured BEFORE the hotkey press."/>
                            <TextBox   Grid.Column="3" x:Name="PreRollBox"/>
                            <TextBlock Grid.Column="4" Text="Post-roll (ms)" Style="{StaticResource LabelCell}" Margin="12,0,0,0"
                                       ToolTip="Keep recording this many ms AFTER the key is released."/>
                            <TextBox   Grid.Column="5" x:Name="PostRollBox"/>
                        </Grid>

                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Direct per-char delay (ms)" Style="{StaticResource LabelCell}"
                                       ToolTip="Only used when Paste method = Direct. 0 = fastest (native desktops). Try 2–3 ms for Citrix/RDP sessions where keystrokes get dropped or reordered."/>
                            <TextBox   Grid.Column="1" x:Name="DirectCharDelayBox"/>
                        </Grid>

                        <TextBlock Text="UI" FontWeight="SemiBold" Foreground="#555" Margin="0,12,0,6"/>
                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Recording overlay" Style="{StaticResource LabelCell}"/>
                            <ComboBox  Grid.Column="1" x:Name="OverlayCombo">
                                <ComboBoxItem Content="None"/>
                                <ComboBoxItem Content="Top"/>
                                <ComboBoxItem Content="Bottom"/>
                            </ComboBox>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="170,4,0,4">
                            <CheckBox x:Name="ShowTrayCheck"  Content="Show tray icon"/>
                            <CheckBox x:Name="StartHiddenCheck" Content="Start hidden (tray only)" Margin="16,0,0,0"/>
                            <CheckBox x:Name="AutostartCheck" Content="Autostart on login" Margin="16,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="HISTORY" FontWeight="SemiBold" Foreground="#555" Margin="0,12,0,6"/>
                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Keep last N entries" Style="{StaticResource LabelCell}"/>
                            <TextBox   Grid.Column="1" x:Name="HistoryLimitBox"/>
                            <Button    Grid.Column="2" Content="Open history browser…" Width="180" HorizontalAlignment="Left"
                                       Margin="12,0,0,0" Click="OnOpenHistory"/>
                        </Grid>

                        <TextBlock Text="UPSTREAM FEATURES NOT PORTED" FontWeight="SemiBold" Foreground="#555" Margin="0,16,0,6"/>
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource Hint}">
                            Custom words · Word-correction threshold · Translate-to-English ·
                            Recording-retention period · Model-unload timeout · Acceleration selector (GPU) ·
                            Keyboard-implementation picker · LLM post-processing · Lazy stream-close ·
                            Experimental toggles. See FEATURES.md for per-feature rationale.
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════ MODELS ═══ -->
            <TabItem Header="Models">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                    <StackPanel>
                        <TextBlock Text="TRANSCRIPTION ENGINE" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,6"/>
                        <Grid Margin="{StaticResource RowMargin}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Backend" Style="{StaticResource LabelCell}"/>
                            <ComboBox Grid.Column="1" x:Name="TranscriptionBackendCombo">
                                <ComboBoxItem Content="Parakeet"/>
                                <ComboBoxItem Content="Whisper"/>
                            </ComboBox>
                            <TextBlock Grid.Column="2" Text="Whisper" Style="{StaticResource LabelCell}" Margin="12,0,0,0"/>
                            <ComboBox Grid.Column="3" x:Name="WhisperModelCombo">
                                <ComboBoxItem Content="tiny"/>
                                <ComboBoxItem Content="base"/>
                                <ComboBoxItem Content="small"/>
                            </ComboBox>
                        </Grid>

                        <TextBlock Text="ACTIVE MODEL" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,6"/>
                        <TextBlock x:Name="ModelPathText" TextTrimming="CharacterEllipsis" Foreground="#444" Margin="0,0,0,12"/>

                        <TextBlock Text="DOWNLOAD PARAKEET" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Variant:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="DownloadVariantCombo" Width="70" SelectedIndex="0">
                                <ComboBoxItem Content="V2"/>
                                <ComboBoxItem Content="V3"/>
                            </ComboBox>
                            <Button x:Name="DownloadButton" Content="Download" Width="100" Margin="8,0,8,0" Click="OnDownloadModel"/>
                            <TextBlock x:Name="DownloadStatus" VerticalAlignment="Center" Foreground="#666"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource Hint}">
                            Parakeet V2 is English-only (~475 MB). V3 is multilingual (~478 MB). The port
                            auto-discovers models placed in %APPDATA%\Handy\models\ or the upstream cache
                            at %APPDATA%\com.pais.handy\models\.
                        </TextBlock>

                        <TextBlock Text="DOWNLOAD WHISPER" FontWeight="SemiBold" Foreground="#555" Margin="0,16,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Model:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="DownloadWhisperModelCombo" Width="80" SelectedIndex="1">
                                <ComboBoxItem Content="tiny"/>
                                <ComboBoxItem Content="base"/>
                                <ComboBoxItem Content="small"/>
                            </ComboBox>
                            <Button x:Name="DownloadWhisperButton" Content="Download" Width="100" Margin="8,0,8,0" Click="OnDownloadWhisperModel"/>
                            <TextBlock x:Name="DownloadWhisperStatus" VerticalAlignment="Center" Foreground="#666"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" Style="{StaticResource Hint}">
                            Whisper.net uses GGML/whisper.cpp models. Handy stores them under
                            %APPDATA%\Handy\models\whisper\ as ggml-tiny.bin, ggml-base.bin, or ggml-small.bin.
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════ LOG ═══ -->
            <TabItem Header="Log">
                <TextBox x:Name="LogBox" IsReadOnly="True" FontFamily="Consolas"
                         VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                         Background="#111" Foreground="#DDD"/>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="1" Text="Settings live at %APPDATA%\Handy\settings.json" Margin="4,8,0,0" Style="{StaticResource Hint}"/>

        <DockPanel Grid.Row="2" Margin="0,8,0,0" LastChildFill="True">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Apply" Width="80" Margin="0,0,8,0" Click="OnApply"/>
                <Button Content="Hide"  Width="80" Margin="0,0,8,0" Click="OnHide"/>
                <Button Content="Quit"  Width="80" Click="OnQuit"/>
            </StackPanel>
            <TextBlock x:Name="SaveStatusText" VerticalAlignment="Center" Margin="4,0,0,0"
                       Foreground="#2a8f3a" FontWeight="SemiBold"/>
        </DockPanel>
    </Grid>
</Window>
