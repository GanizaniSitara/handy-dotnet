<Application x:Class="Handy.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown"
             Startup="OnStartup"
             Exit="OnExit">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Palette: light theme, single blue accent. -->
            <Color x:Key="Color.Text">#FF0F0F0F</Color>
            <Color x:Key="Color.TextSubtle">#FF555555</Color>
            <Color x:Key="Color.Background">#FFFBFBFB</Color>
            <Color x:Key="Color.BackgroundCard">#FFFFFFFF</Color>
            <Color x:Key="Color.MidGray">#FF808080</Color>
            <Color x:Key="Color.Border">#33808080</Color>
            <Color x:Key="Color.BorderStrong">#66808080</Color>
            <Color x:Key="Color.LogoPrimary">#FFA2CAFA</Color>
            <Color x:Key="Color.LogoPrimarySoft">#33A2CAFA</Color>
            <Color x:Key="Color.BackgroundUI">#FF5893DA</Color>
            <Color x:Key="Color.BackgroundUIHover">#FF4A82C8</Color>
            <Color x:Key="Color.Danger">#FFD23B3B</Color>
            <Color x:Key="Color.Success">#FF2A8F3A</Color>

            <SolidColorBrush x:Key="Brush.Text"             Color="{StaticResource Color.Text}"/>
            <SolidColorBrush x:Key="Brush.TextSubtle"       Color="{StaticResource Color.TextSubtle}"/>
            <SolidColorBrush x:Key="Brush.Background"       Color="{StaticResource Color.Background}"/>
            <SolidColorBrush x:Key="Brush.BackgroundCard"   Color="{StaticResource Color.BackgroundCard}"/>
            <SolidColorBrush x:Key="Brush.MidGray"          Color="{StaticResource Color.MidGray}"/>
            <SolidColorBrush x:Key="Brush.Border"           Color="{StaticResource Color.Border}"/>
            <SolidColorBrush x:Key="Brush.BorderStrong"     Color="{StaticResource Color.BorderStrong}"/>
            <SolidColorBrush x:Key="Brush.LogoPrimary"      Color="{StaticResource Color.LogoPrimary}"/>
            <SolidColorBrush x:Key="Brush.LogoPrimarySoft"  Color="{StaticResource Color.LogoPrimarySoft}"/>
            <SolidColorBrush x:Key="Brush.BackgroundUI"     Color="{StaticResource Color.BackgroundUI}"/>
            <SolidColorBrush x:Key="Brush.BackgroundUIHover" Color="{StaticResource Color.BackgroundUIHover}"/>
            <SolidColorBrush x:Key="Brush.Danger"           Color="{StaticResource Color.Danger}"/>
            <SolidColorBrush x:Key="Brush.Success"          Color="{StaticResource Color.Success}"/>

            <!-- Typography: 14px base / 20 line; matches upstream's 15/24 feel for WPF's tighter metrics. -->
            <Style TargetType="TextBlock" x:Key="Text.Base">
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            </Style>

            <Style TargetType="TextBlock" x:Key="Text.SectionGroupTitle" BasedOn="{StaticResource Text.Base}">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource Brush.MidGray}"/>
                <Setter Property="Margin" Value="14,18,0,8"/>
            </Style>

            <Style TargetType="TextBlock" x:Key="Text.SettingLabel" BasedOn="{StaticResource Text.Base}">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="FontWeight" Value="Medium"/>
            </Style>

            <Style TargetType="TextBlock" x:Key="Text.Hint" BasedOn="{StaticResource Text.Base}">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{StaticResource Brush.MidGray}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style TargetType="TextBlock" x:Key="Text.AppTitle" BasedOn="{StaticResource Text.Base}">
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource Brush.BackgroundUI}"/>
            </Style>

            <!-- Default a few primitives so we don't have to repeat ourselves. -->
            <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Base}"/>

            <Thickness x:Key="Row.Padding">12,10,12,10</Thickness>

            <!-- Card containing one section's rows (mimics SettingsGroup.tsx). -->
            <Style TargetType="Border" x:Key="SettingsCard">
                <Setter Property="Background" Value="{StaticResource Brush.BackgroundCard}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Margin" Value="14,0,14,4"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>

            <!-- One row in a card. The first row in a card should override BorderThickness="0". -->
            <Style TargetType="Border" x:Key="SettingsRow">
                <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                <Setter Property="BorderThickness" Value="0,1,0,0"/>
                <Setter Property="Padding" Value="{StaticResource Row.Padding}"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>

            <Style TargetType="Border" x:Key="SettingsRowFirst" BasedOn="{StaticResource SettingsRow}">
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <!-- Sidebar nav item (RadioButton-based so grouping is automatic). -->
            <Style TargetType="RadioButton" x:Key="SidebarItem">
                <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="Margin" Value="6,2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"
                                                  TextElement.FontSize="{TemplateBinding FontSize}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.LogoPrimarySoft}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.LogoPrimary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Buttons. Three variants: primary (solid blue), secondary (light grey), ghost (transparent). -->
            <Style TargetType="Button" x:Key="PrimaryButton">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Padding" Value="14,6"/>
                <Setter Property="MinWidth" Value="80"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{StaticResource Brush.BackgroundUI}"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.BackgroundUIHover}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Button" x:Key="SecondaryButton" BasedOn="{StaticResource PrimaryButton}">
                <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource Brush.BorderStrong}"
                                    BorderThickness="1"
                                    CornerRadius="6" Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.LogoPrimarySoft}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Brush.LogoPrimary}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Light TextBox/ComboBox tweaks: matching border colour + radius without rebuilding the template. -->
            <Style TargetType="TextBox">
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}"/>
                <Setter Property="Background" Value="{StaticResource Brush.BackgroundCard}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}"/>
                <Setter Property="Background" Value="{StaticResource Brush.BackgroundCard}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style TargetType="Slider">
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
